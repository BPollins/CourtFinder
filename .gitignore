# ─── Python (standard) ───────────────────────────────────────────────
# Bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
# Virtual environments
.venv/
venv/
env/
.env/
# Package/build artifacts
*.egg-info/
*.egg
dist/
build/
# Lambda package directory (pip install target)
lambdas/*/package/

# ─── Lambda deployment ───────────────────────────────────────────────
**/*.zip

# ─── IDE & OS (standard) ─────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Secrets & local config (important for security) ──────────────────
.env
.env.local
*.local
secrets.json

# ─── Project-specific ───────────────────────────────────────────────
lambdas/*/run_local.py

# ─── Frontend (Node) ────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.vite/
*.log
